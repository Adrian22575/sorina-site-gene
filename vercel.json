{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/programari",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/appointment-reminders",
      "schedule": "0 5 * * *"
    }
  ]
}
